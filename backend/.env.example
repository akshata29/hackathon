# ============================================================
# Backend environment variables — copy to .env and fill in values
# NEVER commit .env to source control
# ============================================================

# ---- Azure Foundry ----
FOUNDRY_PROJECT_ENDPOINT=https://<hub-name>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_MODEL=gpt-4o

# ---- Azure Cosmos DB ----
AZURE_COSMOS_ENDPOINT=https://<account-name>.documents.azure.com:443/
AZURE_COSMOS_DATABASE=portfolio-advisor
CONVERSATIONS_CONTAINER=conversations

# ---- Azure AI Search ----
AZURE_SEARCH_ENDPOINT=https://<search-name>.search.windows.net
AZURE_SEARCH_INDEX=portfolio-research

# ---- Azure Application Insights ----
# Usually set automatically by Foundry / azd; override here if needed
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# ---- MCP servers ----
YAHOO_MCP_URL=http://localhost:8001/mcp
PORTFOLIO_MCP_URL=http://localhost:8002/mcp
# FRED_MCP_URL=https://fred.stlouisfed.org/mcp   # external / optional

# ---- Entra / MSAL auth ----
# Leave blank to skip JWT validation in local development
ENTRA_TENANT_ID=
ENTRA_AUDIENCE=api://<backend-app-id>

# ---- External API keys (stored in Key Vault in production) ----
YAHOO_FINANCE_API_KEY=
FRED_API_KEY=

# ---- Feature flags ----
ENABLE_SENSITIVE_DATA=false
LOG_LEVEL=INFO
