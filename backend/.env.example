# ============================================================
# Backend environment variables — copy to .env and fill in values
# NEVER commit .env to source control
# In production these are injected by azd / Container Apps.
# ============================================================

# ---- Azure AI Foundry ----
FOUNDRY_PROJECT_ENDPOINT=https://<hub-name>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_MODEL=gpt-4o

# ---- Azure Cosmos DB (conversation history + checkpoints) ----
AZURE_COSMOS_ENDPOINT=https://<account-name>.documents.azure.com:443/
AZURE_COSMOS_DATABASE_NAME=portfolio-advisor
AZURE_COSMOS_CONTAINER_NAME=conversations
AZURE_COSMOS_CHECKPOINTS_CONTAINER=workflow-checkpoints
AZURE_COSMOS_SESSIONS_CONTAINER=chat-sessions
AZURE_COSMOS_KEY=                           # Leave empty to use Managed Identity

# ---- Azure AI Search (RAG) ----
AZURE_SEARCH_ENDPOINT=https://<search-name>.search.windows.net
AZURE_SEARCH_INDEX_NAME=portfolio-research
AZURE_SEARCH_API_KEY=                       # Leave empty to use Managed Identity

# ---- Azure Monitor / OpenTelemetry ----
# Usually set automatically by azd; override for local dev
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
OTEL_SERVICE_NAME=portfolio-advisor-backend
ENABLE_INSTRUMENTATION=true
ENABLE_SENSITIVE_DATA=false                 # Never true in production

# ---- Entra ID (authentication) ----
# Leave blank to skip JWT validation in local development
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=                            # Frontend SPA app registration
ENTRA_BACKEND_CLIENT_ID=                    # Backend API app registration

# ---- Managed Identity ----
# Leave empty for local dev; set in Container Apps deployment
AZURE_CLIENT_ID=

# ---- MCP servers ----
YAHOO_MCP_URL=http://localhost:8001
PORTFOLIO_MCP_URL=http://localhost:8002
MCP_AUTH_TOKEN=dev-portfolio-mcp-token

# ---- External API keys (stored in Key Vault in production) ----
ALPHAVANTAGE_API_KEY=

# ---- Foundry agent names (created by scripts/setup-foundry.py) ----
MARKET_INTEL_AGENT_NAME=portfolio-market-intel
PORTFOLIO_DATA_AGENT_NAME=portfolio-data-agent
ECONOMIC_DATA_AGENT_NAME=portfolio-economic-agent
PRIVATE_DATA_AGENT_NAME=portfolio-private-data-agent

# ---- Bing Grounding connection ID (optional) ----
# Set to the connection_id of your Bing resource in the Foundry project
BING_CONNECTION_ID=

# ---- GitHub OAuth App (Pattern 2: vendor OAuth per-user token) ----
# Create at: https://github.com/settings/developers -> OAuth Apps
# Homepage URL:      http://localhost:5173
# Callback URL:      http://localhost:8000/api/auth/github/callback
# Store client secret in Key Vault in production (never commit the value)FRONTEND_URL=http://localhost:5173GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/github/callback
