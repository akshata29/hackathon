# =============================================================
# Backend environment variables
# Copy to .env for local development. Never commit .env.
# In production these are injected by azd / Container Apps.
# =============================================================

# ---------------------------------------------------------------
# CORE INFRASTRUCTURE  (required by every use-case)
# ---------------------------------------------------------------

# Azure AI Foundry project endpoint
# Format: https://<resource>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
FOUNDRY_MODEL=gpt-4o

# Azure Cosmos DB (conversation history + checkpoints)
AZURE_COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
AZURE_COSMOS_DATABASE_NAME=your-app-db
AZURE_COSMOS_CONTAINER_NAME=conversations
AZURE_COSMOS_CHECKPOINTS_CONTAINER=workflow-checkpoints
AZURE_COSMOS_SESSIONS_CONTAINER=chat-sessions
AZURE_COSMOS_KEY=                     # Leave empty to use Managed Identity

# Azure AI Search (optional RAG)
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_INDEX_NAME=your-index
AZURE_SEARCH_API_KEY=                 # Leave empty to use Managed Identity

# Azure Monitor / OpenTelemetry
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
OTEL_SERVICE_NAME=your-app-backend
ENABLE_INSTRUMENTATION=true
ENABLE_SENSITIVE_DATA=false           # Never true in production

# Entra ID (authentication)
ENTRA_TENANT_ID=your-tenant-id
ENTRA_CLIENT_ID=your-frontend-spa-client-id
ENTRA_BACKEND_CLIENT_ID=your-backend-api-client-id

# Entra OBO -- client secret for token exchange to downstream MCP servers
# Retrieve from Key Vault after running scripts/post-provision.ps1
# NEVER commit this value to source control
ENTRA_CLIENT_SECRET=

# MCP server Entra app registration IDs (one per confidential MCP server)
# Used by build_obo_http_client() to set the correct JWT audience
# MY_MCP_CLIENT_ID=your-mcp-app-registration-client-id

# Managed Identity (leave empty for local dev, set in Container Apps)
AZURE_CLIENT_ID=

# ---------------------------------------------------------------
# DOMAIN-SPECIFIC  (replace with your own variables)
# ---------------------------------------------------------------

# TODO: Add your domain-specific environment variables here.
# Example MCP server URLs:
# MY_MCP_URL=http://localhost:8001
# MCP_AUTH_TOKEN=dev-token

# ---------------------------------------------------------------
# VENDOR OAUTH (Pattern 2 -- per-user vendor token)  (optional)
# ---------------------------------------------------------------
# Create a GitHub OAuth App at: https://github.com/settings/developers
# Homepage URL:      http://localhost:5173
# Callback URL:      http://localhost:8000/api/auth/github/callback
# Store client secret in Key Vault in production.
FRONTEND_URL=http://localhost:5173
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/github/callback
