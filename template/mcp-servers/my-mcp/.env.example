# ============================================================
# Environment variables for my-mcp server
# Copy to .env and fill in the values for local development.
# In production these are injected by Container Apps / Key Vault.
# ============================================================

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------

# Shared bearer token for dev mode (ENTRA_TENANT_ID not set).
# Must match MCP_AUTH_TOKEN in the backend .env.
MCP_AUTH_TOKEN=dev-mcp-token-change-me

# Entra ID tenant for JWT validation (production).
# Leave empty for local dev -- falls back to static token above.
ENTRA_TENANT_ID=

# This server's app registration client ID.
# Tokens issued by OBO must have audience = api://<MCP_CLIENT_ID>.
MCP_CLIENT_ID=

# Optional: comma-separated list of additional trusted OIDC issuers (Option B multi-IDP).
# Entra is always trusted. Only set this to add more IdPs.
# Example: TRUSTED_ISSUERS=https://dev-xxxxx.okta.com
TRUSTED_ISSUERS=

# Optional: JWKS cache TTL in seconds (default 3600 = 1 hour).
JWKS_CACHE_TTL=3600

# ---------------------------------------------------------------------------
# Data access  (TODO: replace with your data source variables)
# ---------------------------------------------------------------------------

# DB_PATH=data/my-app.db        # SQLite for local dev
# DB_CONNECTION_STRING=         # SQL Server / Postgres for production
# API_BASE_URL=                 # REST API base URL
# API_KEY=                      # API key (store in Key Vault in production)

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
# APPLICATIONINSIGHTS_CONNECTION_STRING=    # uncomment to enable telemetry
