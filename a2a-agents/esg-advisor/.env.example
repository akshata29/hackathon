PORT=8010
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# LLM Configuration — choose ONE option
# ---------------------------------------------------------------------------

# Option A: Azure OpenAI (recommended for production)
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
# AZURE_OPENAI_API_KEY=<your-key>   # optional when using managed identity

# Option B: OpenAI
# OPENAI_API_KEY=<your-key>
# OPENAI_MODEL=gpt-4o-mini
# ---------------------------------------------------------------------------
# Entra Agent Identity auth (demo_mode=entra-agent)
# ---------------------------------------------------------------------------
# Set ESG_REQUIRE_AGENT_AUTH=true to enforce Bearer token validation on all
# incoming A2A requests except /.well-known/agent.json discovery.
# Leave false (default) for the original unauthenticated A2A demo mode.
ESG_REQUIRE_AGENT_AUTH=false

# Entra tenant for JWKS discovery (required when ESG_REQUIRE_AGENT_AUTH=true).
ENTRA_TENANT_ID=

# App registration client ID for THIS server. Tokens must carry aud=api://<ESG_CLIENT_ID>.
# Leave blank to skip audience validation (less strict; dev only).
ESG_CLIENT_ID=

# Static dev token accepted when ENTRA_TENANT_ID is blank.
ESG_DEV_TOKEN=dev-esg-token

# Object ID (oid) of the backend agent service principal.
# Must match AGENT_IDENTITY_ID in the backend and MCP servers.
# Leave blank to accept any valid app-only Entra token (dev/testing only).
AGENT_IDENTITY_ID=