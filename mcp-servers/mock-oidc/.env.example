# Mock OIDC Server — environment configuration
# Copy to .env and adjust as needed.

# Port this server listens on (default: 8888)
MOCK_OIDC_PORT=8888

# Base URL as seen by clients.  Change if behind a reverse proxy or ngrok.
MOCK_OIDC_BASE_URL=http://localhost:8888

# Default audience embedded in issued tokens.
# MUST match the MCP_CLIENT_ID value on your MCP servers (e.g. api://<entra-client-id>).
# In dev mode (no real Entra), use: api://mock-mcp-client
TOKEN_AUDIENCE=api://mock-mcp-client

# Token lifetime in seconds (default: 3600 = 1 hour)
TOKEN_LIFETIME_SECONDS=3600
