# Yahoo Finance MCP Server — environment configuration
# Copy to .env and fill in production values.

# ---------------------------------------------------------------------------
# Entra ID (production)
# ---------------------------------------------------------------------------
# Entra tenant ID.  Leave blank to run in dev mode (static token auth).
ENTRA_TENANT_ID=

# App registration client ID for THIS MCP server (the resource, not the caller).
# Tokens presented to this server must have: aud = api://<MCP_CLIENT_ID>
MCP_CLIENT_ID=

# ---------------------------------------------------------------------------
# Dev mode (only used when ENTRA_TENANT_ID is blank)
# ---------------------------------------------------------------------------
# Static bearer token accepted in dev mode.  The backend sends this value.
MCP_AUTH_TOKEN=dev-yahoo-mcp-token

# ---------------------------------------------------------------------------
# Option B — Multi-IDP (Okta / any OIDC provider)
# ---------------------------------------------------------------------------
# Comma-separated list of OIDC issuer URLs to trust IN ADDITION to Entra.
# Tokens from these issuers are validated via their own JWKS.
# Their audience claim must still match: api://<MCP_CLIENT_ID>
#
# Local demo (mock OIDC server):
#   TRUSTED_ISSUERS=http://localhost:8888
#
# Real Okta:
#   TRUSTED_ISSUERS=https://dev-xxxxx.okta.com/oauth2/default
TRUSTED_ISSUERS=

# ---------------------------------------------------------------------------
# Azure (optional — Content Safety, App Insights)
# ---------------------------------------------------------------------------
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
KEY_VAULT_URL=
CONTENT_SAFETY_ENDPOINT=
# ---------------------------------------------------------------------------
# Option D -- Entra Agent Identity (demo_mode=entra-agent)
# ---------------------------------------------------------------------------
# Object ID (oid) of the backend agent service principal.
# When set, app-only Entra tokens (no scp claim) are pinned to this oid.
# Leave blank to accept any valid app-only Entra token (dev/testing only).
AGENT_IDENTITY_ID=APPLICATIONINSIGHTS_CONNECTION_STRING=
