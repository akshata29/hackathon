# Okta-to-Entra Token Exchange Proxy (Option C) — environment configuration
# Copy to .env and fill in values.

# ---------------------------------------------------------------------------
# Proxy network
# ---------------------------------------------------------------------------
# Port this proxy listens on.
PROXY_PORT=8003

# ---------------------------------------------------------------------------
# Incoming token validation (Okta / mock-OIDC)
# ---------------------------------------------------------------------------
# OIDC issuer URL of the token source.
# Local demo: http://localhost:8888
# Real Okta:  https://dev-xxxxx.okta.com/oauth2/default
OKTA_ISSUER=http://localhost:8888

# Audience expected in the incoming token.
# Must match what the token issuer puts in the 'aud' claim.
# Local demo: api://mock-mcp-client
# Real Okta:  api://<your-okta-app-client-id>
OKTA_AUDIENCE=api://mock-mcp-client

# ---------------------------------------------------------------------------
# Downstream MCP server
# ---------------------------------------------------------------------------
# URL of the MCP server this proxy forwards to.
# Yahoo Finance local: http://localhost:8001
# Portfolio DB local:  http://localhost:8002
TARGET_MCP_URL=http://localhost:8001

# ---------------------------------------------------------------------------
# Dev mode (ENTRA_TENANT_ID blank)
# ---------------------------------------------------------------------------
# Static token injected into forwarded requests.
# Must match MCP_AUTH_TOKEN on the target MCP server.
TARGET_MCP_TOKEN=dev-yahoo-mcp-token

# ---------------------------------------------------------------------------
# Production mode (ENTRA_TENANT_ID set)
# ---------------------------------------------------------------------------
# The proxy calls Entra with client_credentials to get a service token
# for the MCP app registration (audience = api://<MCP_CLIENT_ID>).

# Your Entra tenant ID.
ENTRA_TENANT_ID=

# The proxy's own Entra app registration (a confidential client with
# permission to call api://<MCP_CLIENT_ID>).
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# App registration client ID of the TARGET MCP server.
MCP_CLIENT_ID=

# ---------------------------------------------------------------------------
# User identity mapping (Okta sub/email -> Entra UPN)
# ---------------------------------------------------------------------------
# JSON object mapping Okta user identifiers to MCP-side user identities.
# If a user is not listed their Okta email/sub is forwarded unchanged.
# Example:
#   USER_MAPPING={"alice@okta.example":"alice@company.onmicrosoft.com","bob|abc123":"bob@company.onmicrosoft.com"}
USER_MAPPING={}

# ---------------------------------------------------------------------------
# Other
# ---------------------------------------------------------------------------
JWKS_CACHE_TTL=3600
LOG_LEVEL=INFO
